<?xml version="1.0" encoding="UTF-8"?>
<Wix
  xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="PillowLock"
    Manufacturer="PillowLock"
    Version="$(var.AppVersion)"
    UpgradeCode="2EF7A24C-9497-4DD3-BD94-1283DB5F6C6C"
    Language="1033"
    Scope="perMachine">
    <SummaryInformation
      Description="PillowLock"
      Manufacturer="PillowLock" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Icon Id="AppIcon" SourceFile="$(var.RepoRoot)\assets\branding\logo.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <WixVariable Id="WixUIBannerBmp" Value="$(var.RepoRoot)\assets\branding\installer-msi-banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="$(var.RepoRoot)\assets\branding\installer-msi-dialog.bmp" />
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="PillowLock">
        <Component Id="MainExecutableComponent" Guid="*" Bitness="always64">
          <File
            Id="MainExecutableFile"
            Source="$(var.BuildOutputDir)\pillowlock.exe"
            KeyPath="yes">
            <Shortcut
              Id="DesktopShortcut"
              Directory="DesktopFolder"
              Name="PillowLock"
              WorkingDirectory="INSTALLFOLDER"
              Icon="AppIcon"
              Advertise="no" />
            <Shortcut
              Id="StartMenuShortcut"
              Directory="ApplicationProgramsFolder"
              Name="PillowLock"
              WorkingDirectory="INSTALLFOLDER"
              Icon="AppIcon"
              Advertise="no" />
          </File>
        </Component>
        <Component Id="FileIconComponent" Guid="*" Bitness="always64">
          <File
            Id="VaultFileIcon"
            Source="$(var.RepoRoot)\assets\branding\logo.ico"
            Name="pillowlock.ico"
            KeyPath="yes" />
        </Component>
        <Component Id="FileAssociationComponent" Guid="*" Bitness="always64">
          <RegistryKey Root="HKLM" Key="Software\Classes\.plock">
            <RegistryValue Type="string" Value="PillowLock.Vault" KeyPath="yes" />
          </RegistryKey>
          <RegistryKey Root="HKLM" Key="Software\Classes\PillowLock.Vault">
            <RegistryValue Type="string" Value="PillowLock Vault File" />
            <RegistryKey Key="DefaultIcon">
              <RegistryValue Type="string" Value="[#VaultFileIcon]" />
            </RegistryKey>
            <RegistryKey Key="shell\open\command">
              <RegistryValue Type="string" Value="&quot;[#MainExecutableFile]&quot; &quot;%1&quot;" />
            </RegistryKey>
          </RegistryKey>
        </Component>
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="PillowLock">
        <Component Id="StartMenuFolderCleanupComponent" Guid="*">
          <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
          <RegistryValue
            Root="HKCU"
            Key="Software\PillowLock"
            Name="StartMenuShortcutInstalled"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="PillowLock" Level="1">
      <ComponentRef Id="MainExecutableComponent" />
      <ComponentRef Id="FileIconComponent" />
      <ComponentRef Id="FileAssociationComponent" />
      <ComponentRef Id="StartMenuFolderCleanupComponent" />
    </Feature>
  </Package>
</Wix>
